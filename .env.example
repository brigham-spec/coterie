# Copy to `.env` and fill in real values. `.env` is gitignored.

# ── Database: Neon Postgres (TWO roles — tenant isolation depends on this) ──
# Neon's owner role has BYPASSRLS, so it would silently defeat row-level
# security. The app therefore connects as a restricted role; migrations use the
# owner. Create the restricted role after migrating:
#   DIRECT_URL=... APP_DB_PASSWORD=... node scripts/bootstrap-app-role.mjs
#
# Use sslmode=verify-full (not `require`): Neon presents publicly-trusted certs,
# so it validates, and it avoids the pg-connection-string deprecation warning —
# `require` becomes a weaker, non-verifying mode in pg v9.
#
# app_user (NOBYPASSRLS) — the app runtime and tests. RLS IS enforced here.
DATABASE_URL="postgresql://app_user:APP_PASSWORD@HOST/DBNAME?sslmode=verify-full"
# neondb_owner (owner) — `prisma migrate` and admin scripts ONLY. Bypasses RLS.
DIRECT_URL="postgresql://OWNER:PASSWORD@HOST/DBNAME?sslmode=verify-full"
# Password for app_user; used by scripts/bootstrap-app-role.mjs to (re)create it.
APP_DB_PASSWORD="APP_PASSWORD"

# ── Clerk: auth + organizations ──────────────────────────────────────────
# Clerk dashboard → API keys.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_xxx"
CLERK_SECRET_KEY="sk_test_xxx"

# ── Anthropic: AI briefs (server-side only — never exposed to the client) ──
# console.anthropic.com → API keys. Do NOT wrap in curly quotes (a TextEdit
# Rich-Text paste turns "..." into smart quotes and breaks parsing).
ANTHROPIC_API_KEY="sk-ant-xxx"

# ── Integration credential encryption (server-side only) ─────────────────
# Encrypts per-org OAuth tokens (integration_credentials.*_enc) before they
# touch the DB — the database only ever sees ciphertext. AES-256-GCM, so this
# must be exactly 32 bytes, base64-encoded. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# ROTATING THIS ORPHANS EVERY STORED TOKEN — treat it as permanent.
INTEGRATION_ENC_KEY="base64-encoded-32-bytes"
