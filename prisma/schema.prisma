// Coterie v1 — database schema.
// Source of truth: coterie-v1-schema-spec.md (spec §3). Read the spec before
// changing anything here. Deviations from the spec's literal column lists are
// noted inline with a rationale.
//
// Conventions (spec §3): all PKs are uuid; every tenant table carries org_id
// (uuid NOT NULL, FK -> organizations) and gets an RLS policy (added in a
// later migration, build-order item 3); all tables carry created_at/updated_at.
// DB identifiers are snake_case (RLS SQL references them); the Prisma client
// surface is camelCase via @map/@@map.
//
// Status/type fields are `text` (String) by ratified decision — "status is a
// field, not separate tables" (spec §2, decision #2). Allowed values are
// documented in comments; validate at boundaries, not via Postgres enums
// (deliberately avoided so lifecycle vocabularies can evolve additively).

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────────────────────────
// Platform-level identity (NOT tenant-scoped)
// ─────────────────────────────────────────────────────────────────────────────

/// The tenant. One row per client org (spec §3.1). Not itself tenant-scoped.
model Organization {
  id       String  @id @default(uuid()) @db.Uuid
  /// Clerk organization id (org_…) — the bridge from a signed-in session's
  /// active org to our tenant uuid (fed into app.org_id / withOrg). Mirrors
  /// users.clerk_id. Nullable + unique: seeded test tenants and the HVEDC data
  /// migration have no Clerk org, and Postgres unique permits multiple NULLs.
  clerkId  String? @unique @map("clerk_id")
  name     String
  /// Label only in v1: edc, chamber, council, ria (no workflow branching yet).
  orgType  String  @map("org_type")
  /// Feature flags, sync windows, branding.
  settings Json    @default("{}")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  memberships            OrgMembership[]
  companies              Company[]
  contacts               Contact[]
  projects               Project[]
  projectLinks           ProjectLink[]
  introductions          Introduction[]
  meetings               Meeting[]
  meetingAttendees       MeetingAttendee[]
  actionItems            ActionItem[]
  invoices               Invoice[]
  payments               Payment[]
  newsItems              NewsItem[]
  emailMessages          EmailMessage[]
  activities             Activity[]
  integrationCredentials IntegrationCredential[]
  events                 Event[]
  eventInvitees          EventInvitee[]
  membershipProposals    MembershipProposal[]
  valueDelivered         ValueDelivered[]
  affiliations           Affiliation[]
  introDismissals        IntroDismissal[]
  unmatchedAttendees     UnmatchedAttendee[]
  aiRateLimit            AiRateLimit?

  @@map("organizations")
}

/// Platform-level identity (spec §3.2). One human = one row (managed by Clerk),
/// spanning orgs via org_memberships. No org_id: identity is shared, data is not.
model User {
  id      String @id @default(uuid()) @db.Uuid
  clerkId String @unique @map("clerk_id")
  email   String @unique
  name    String

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  memberships      OrgMembership[]
  ownedActionItems ActionItem[]    @relation("ActionItemOwnerUser")
  activities       Activity[]      @relation("ActivityActor")
  ownedCompanies   Company[]       @relation("CompanyOwner")

  @@map("users")
}

/// Junction: which users belong to which org, in what role (spec §3.3).
model OrgMembership {
  orgId  String @map("org_id") @db.Uuid
  userId String @map("user_id") @db.Uuid
  /// admin, staff
  role   String

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([orgId, userId])
  @@index([userId])
  @@map("org_memberships")
}

// ─────────────────────────────────────────────────────────────────────────────
// Tenant-scoped tables (every one carries org_id + RLS)
// ─────────────────────────────────────────────────────────────────────────────

/// The managed relationship — the central table (spec §3.4). Relationship
/// attributes (status, tier, temperature, value) live here, not on contacts.
model Company {
  id          String  @id @default(uuid()) @db.Uuid
  orgId       String  @map("org_id") @db.Uuid
  name        String
  /// prospect, member, strategic_partner, former (lifecycle, not separate tables)
  status      String
  /// e.g. strategic_partner_10k, executive_board_20k, chairmans_circle_50k
  tier        String?
  /// Relationship strength score (demo's `lk`). Company-level only in v1.
  temperature Int?
  industry    String
  /// Standardized on dollars (not thousands) — spec §2, conventions.
  annualValue Decimal @map("annual_value") @db.Decimal(14, 2)
  website     String?
  /// Drives Fireflies attendee -> company matching.
  emailDomain String? @map("email_domain")
  /// How the relationship originated (demo's `src`).
  source      String?
  notes       String  @default("")

  // ── Slice 11.0 additive expansion (all nullable / defaulted; backfilled) ──
  /// HV counties served (demo `counties`). Filter bars.
  counties       String[]  @default([])
  /// Typical deal size, free text (demo `dealSize`).
  dealSize       String?   @map("deal_size")
  /// What they need from the network — drives the intro engine (demo `lookingFor`).
  lookingFor     String?   @map("looking_for")
  /// What they bring — drives the intro engine (demo `canOffer`).
  canOffer       String?   @map("can_offer")
  /// Gov/agency relationships (demo `agencyContacts`).
  agencyContacts String?   @map("agency_contacts")
  /// Org tags: seeking_equity, ida_active, … (demo `networkTags`). Filter bars.
  networkTags    String[]  @default([]) @map("network_tags")
  /// Relationship owner. Plain FK to users.id — app-layer boundary-checked
  /// inside withOrg (users is platform-level, so no composite-FK guard applies).
  ownerUserId    String?   @map("owner_user_id") @db.Uuid
  /// Year joined (demo `memberSince`). Matches invoice installment logic.
  memberSince    Int?      @map("member_since")
  /// Newest note/meeting touch — powers the Needs-a-Call panel. App-maintained.
  lastContactAt  DateTime? @map("last_contact_at") @db.Timestamptz(6)
  /// Nested/evolving service tracking: { ida:{…}, capital:{…} }.
  services       Json      @default("{}")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  organization          Organization         @relation(fields: [orgId], references: [id], onDelete: Cascade)
  owner                 User?                @relation("CompanyOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  contacts              Contact[]
  projectLinks          ProjectLink[]
  invoices              Invoice[]
  newsItems             NewsItem[]
  emailMessages         EmailMessage[]
  activities            Activity[]
  membershipProposals   MembershipProposal[]
  valueDelivered        ValueDelivered[]
  affiliations          Affiliation[]
  dismissalsAsFocus     IntroDismissal[]     @relation("IntroDismissalFocus")
  dismissalsAsCandidate IntroDismissal[]     @relation("IntroDismissalCandidate")

  // Composite-FK target so tenant junctions (project_links) can reference
  // (id, org_id) and never point at a company in another org.
  @@unique([id, orgId])
  @@index([orgId])
  @@index([orgId, status])
  @@index([orgId, emailDomain])
  @@map("companies")
}

/// People at companies (spec §3.5). Tenant-scoped even when the same human
/// exists in another org's tenant — sealed silos.
model Contact {
  id        String  @id @default(uuid()) @db.Uuid
  orgId     String  @map("org_id") @db.Uuid
  companyId String  @map("company_id") @db.Uuid
  name      String
  /// Primary key for meeting matching.
  email     String?
  phone     String?
  title     String?
  /// The main relationship contact at the firm.
  isPrimary Boolean @default(false) @map("is_primary")
  notes     String  @default("")

  // ── Slice 11.0 additive expansion ──
  /// Profile URL (demo `linkedin`).
  linkedin String?
  /// Contact tags: decision_maker, hnw, family_office, … (demo `tags`).
  tags     String[] @default([])

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  organization     Organization      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  company          Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  introsAsPartyA   Introduction[]    @relation("IntroPartyA")
  introsAsPartyB   Introduction[]    @relation("IntroPartyB")
  meetingAttendees MeetingAttendee[]
  ownedActionItems ActionItem[]      @relation("ActionItemOwnerContact")
  eventInvitees    EventInvitee[]

  // Composite-FK target for meeting_attendees (id, org_id).
  @@unique([id, orgId])
  @@index([orgId])
  @@index([companyId])
  @@index([orgId, email])
  @@map("contacts")
}

/// Multi-party initiatives — relocations, developments, cluster efforts (spec §3.6).
model Project {
  id          String    @id @default(uuid()) @db.Uuid
  orgId       String    @map("org_id") @db.Uuid
  name        String
  /// Pipeline stage — enum defined per product needs. Vocabulary (demo's board):
  /// concept, pre_development, entitlements, planning_board, capital_raise,
  /// construction_docs, under_construction, stabilization, completed, on_hold.
  stage       String
  description String    @default("")
  targetDate  DateTime? @map("target_date") @db.Date
  value       Decimal?  @db.Decimal(14, 2)

  // ── Slice 11.0 additive expansion (all nullable / defaulted; backfilled) ──
  /// Project type / industry (demo `type`).
  type           String?
  /// Location (demo `county`).
  county         String?
  /// Units / keys — pipeline metric (demo `units`).
  units          Int?
  /// Value actually realized — powers Value Created (demo `realizedValue`).
  realizedValue  Decimal? @map("realized_value") @db.Decimal(14, 2)
  /// Lead org/name if not yet a member (demo `prospectLead`).
  prospectLead   String?  @map("prospect_lead")
  /// { permanentJobs, constructionJobs, constructionCost, taxAbatement, grants[] }.
  economicImpact Json     @default("{}") @map("economic_impact")
  /// { capitalSourcing, idaNavigation, realEstateSales, grantCfa }.
  hvServices     Json     @default("{}") @map("hv_services")
  /// [{ name, amount, status }] — funding sources (demo `fundingSources`).
  fundingSources Json     @default("[]") @map("funding_sources")
  /// [{ stage, date }] — stage transitions (Activity is company-scoped, not project).
  stageHistory   Json     @default("[]") @map("stage_history")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  organization  Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  projectLinks  ProjectLink[]
  introductions Introduction[]
  events        Event[]

  // Composite-FK target for project_links (id, org_id).
  @@unique([id, orgId])
  @@index([orgId])
  @@map("projects")
}

/// Many-to-many: which companies participate in which projects, and how (spec §3.7).
/// Carries org_id (beyond the spec's literal column list) per CLAUDE.md cardinal
/// rule #1 so RLS scopes this table directly instead of via joins. Ratified.
/// The item-3 migration adds composite FKs so a link can never straddle orgs:
///   (org_id, project_id) -> projects(org_id, id)
///   (org_id, company_id) -> companies(org_id, id)
model ProjectLink {
  orgId     String @map("org_id") @db.Uuid
  projectId String @map("project_id") @db.Uuid
  companyId String @map("company_id") @db.Uuid
  /// Team role. Base vocab: developer, lender, site_host, agency, advisor.
  /// Slice 11.0 expands to the demo's 20 disciplines (architect, civil_engineer,
  /// land_use_attorney, bridge_lender, general_contractor, interior_designer,
  /// owners_rep, environmental, landscape_architect, design_architect,
  /// structural_engineer, mep_engineer, historic_preservation, equity_partner,
  /// tax_credit_consultant, hospitality_operator, surveyor, traffic_engineer,
  /// permitting_consultant, …). Open-role detection = disciplines with no link.
  role      String

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  // Composite FKs include org_id so a link's parents must be in the SAME org.
  project      Project      @relation(fields: [projectId, orgId], references: [id, orgId], onDelete: Cascade)
  company      Company      @relation(fields: [companyId, orgId], references: [id, orgId], onDelete: Cascade)

  @@id([projectId, companyId])
  @@index([orgId])
  @@index([companyId])
  @@map("project_links")
}

/// First-class object — the product's core verb (spec §3.8). Generates the board report.
model Introduction {
  id              String    @id @default(uuid()) @db.Uuid
  orgId           String    @map("org_id") @db.Uuid
  partyAContactId String    @map("party_a_contact_id") @db.Uuid
  partyBContactId String    @map("party_b_contact_id") @db.Uuid
  /// suggested, drafted, made, meeting_held, closed
  status          String
  /// manual, detected (Fireflies title scan), ai_suggested
  source          String
  /// Free text or enum: what came of it.
  outcome         String?
  madeOn          DateTime? @map("made_on") @db.Date
  /// If the intro advanced a specific project.
  projectId       String?   @map("project_id") @db.Uuid
  notes           String    @default("")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  organization   Organization     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  partyA         Contact          @relation("IntroPartyA", fields: [partyAContactId], references: [id])
  partyB         Contact          @relation("IntroPartyB", fields: [partyBContactId], references: [id])
  project        Project?         @relation(fields: [projectId], references: [id])
  valueDelivered ValueDelivered[]

  @@index([orgId])
  @@index([partyAContactId])
  @@index([partyBContactId])
  @@index([projectId])
  @@map("introductions")
}

/// Synced from Fireflies, or manually created (spec §3.9).
model Meeting {
  id            String   @id @default(uuid()) @db.Uuid
  orgId         String   @map("org_id") @db.Uuid
  /// Null for manual meetings; unique for sync idempotency.
  firefliesId   String?  @unique @map("fireflies_id")
  title         String
  heldAt        DateTime @map("held_at") @db.Timestamptz(6)
  summary       String?
  transcriptUrl String?  @map("transcript_url")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  organization Organization      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  attendees    MeetingAttendee[]
  actionItems  ActionItem[]

  // Composite-FK target for meeting_attendees (id, org_id).
  @@unique([id, orgId])
  @@index([orgId])
  @@index([orgId, heldAt(sort: Desc)])
  @@map("meetings")
}

/// Junction with match provenance (spec §3.10). Low-confidence matches are
/// surfaced for human confirmation, never silently merged.
/// Carries org_id (beyond the spec's literal column list) per cardinal rule #1;
/// ratified. The item-3 migration adds composite FKs to prevent cross-org links:
///   (org_id, meeting_id) -> meetings(org_id, id)
///   (org_id, contact_id) -> contacts(org_id, id)
model MeetingAttendee {
  orgId       String  @map("org_id") @db.Uuid
  meetingId   String  @map("meeting_id") @db.Uuid
  contactId   String  @map("contact_id") @db.Uuid
  /// email, domain, display_name, surname, manual
  matchMethod String  @map("match_method")
  /// 0–1; surface < threshold for confirmation.
  confidence  Float
  /// Human-verified match.
  confirmed   Boolean @default(false)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  // Composite FKs include org_id so an attendee's meeting and contact must be
  // in the SAME org — a cross-org attendee row cannot exist.
  meeting      Meeting      @relation(fields: [meetingId, orgId], references: [id, orgId], onDelete: Cascade)
  contact      Contact      @relation(fields: [contactId, orgId], references: [id, orgId], onDelete: Cascade)

  @@id([meetingId, contactId])
  @@index([orgId])
  @@index([contactId])
  @@map("meeting_attendees")
}

/// Commitments, from meetings or manual entry (spec §3.11). Polymorphic owner:
/// exactly one of owner_user_id ("we owe") / owner_contact_id ("they owe").
/// The XOR is enforced by a CHECK constraint added via raw SQL in the migration
/// (Prisma schema cannot express CHECK constraints) — see build-order item 3.
model ActionItem {
  id             String    @id @default(uuid()) @db.Uuid
  orgId          String    @map("org_id") @db.Uuid
  /// Null for manually created items.
  meetingId      String?   @map("meeting_id") @db.Uuid
  text           String
  /// open, done, dropped
  status         String    @default("open")
  dueDate        DateTime? @map("due_date") @db.Date
  /// Staff-owned ("we owe").
  ownerUserId    String?   @map("owner_user_id") @db.Uuid
  /// Network-owned ("they owe").
  ownerContactId String?   @map("owner_contact_id") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  meeting      Meeting?     @relation(fields: [meetingId], references: [id], onDelete: SetNull)
  ownerUser    User?        @relation("ActionItemOwnerUser", fields: [ownerUserId], references: [id])
  ownerContact Contact?     @relation("ActionItemOwnerContact", fields: [ownerContactId], references: [id])

  @@index([orgId])
  @@index([orgId, status, dueDate])
  @@map("action_items")
}

/// QuickBooks-shaped (spec §3.12). A payment schedule = multiple invoices
/// sharing a parent. "paid"/"partial" is derived from payments, never a flag.
model Invoice {
  id              String   @id @default(uuid()) @db.Uuid
  orgId           String   @map("org_id") @db.Uuid
  companyId       String   @map("company_id") @db.Uuid
  /// Org-visible number; unique per org.
  invoiceNumber   String   @map("invoice_number")
  /// Links affiliated/installment invoices.
  parentInvoiceId String?  @map("parent_invoice_id") @db.Uuid
  amount          Decimal  @db.Decimal(14, 2)
  issuedOn        DateTime @map("issued_on") @db.Date
  dueOn           DateTime @map("due_on") @db.Date
  /// draft, sent, partial, paid, void — partial/paid derived from payments.
  status          String   @default("draft")
  /// Future QuickBooks sync.
  quickbooksId    String?  @map("quickbooks_id")
  notes           String   @default("")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  company      Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  parent       Invoice?     @relation("InvoiceSchedule", fields: [parentInvoiceId], references: [id])
  children     Invoice[]    @relation("InvoiceSchedule")
  payments     Payment[]

  @@unique([orgId, invoiceNumber])
  @@index([orgId])
  @@index([companyId])
  @@index([parentInvoiceId])
  @@map("invoices")
}

/// Actual money received against an invoice (spec §3.13).
model Payment {
  id           String   @id @default(uuid()) @db.Uuid
  orgId        String   @map("org_id") @db.Uuid
  invoiceId    String   @map("invoice_id") @db.Uuid
  amount       Decimal  @db.Decimal(14, 2)
  receivedOn   DateTime @map("received_on") @db.Date
  /// check, ach, card, …
  method       String?
  /// Future QuickBooks sync.
  quickbooksId String?  @map("quickbooks_id")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  invoice      Invoice      @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([invoiceId])
  @@map("payments")
}

/// Persisted News Intelligence — localStorage in the demo (spec §3.14).
model NewsItem {
  id         String   @id @default(uuid()) @db.Uuid
  orgId      String   @map("org_id") @db.Uuid
  companyId  String   @map("company_id") @db.Uuid
  headline   String
  url        String
  summary    String?
  capturedAt DateTime @map("captured_at") @db.Timestamptz(6)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  company      Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([companyId])
  @@map("news_items")
}

/// Synced client correspondence (slice 11.12). Zapier analyses each inbound email
/// with Claude and appends a row to a published Google Sheet; a sync pulls that
/// CSV, matches each row to a company, and lands it here. companyId is nullable —
/// unmatched mail is still stored so it surfaces in an "Unmatched" bucket. Plain
/// FK (SetNull on company delete); matching runs inside withOrg so the assigned
/// company is always same-tenant. Deduped by (orgId, externalKey).
model EmailMessage {
  id          String   @id @default(uuid()) @db.Uuid
  orgId       String   @map("org_id") @db.Uuid
  companyId   String?  @map("company_id") @db.Uuid
  /// thread_id from the sheet, or a date+from_email fallback — the dedupe key.
  externalKey String   @map("external_key")
  fromName    String   @default("") @map("from_name")
  fromEmail   String   @default("") @map("from_email")
  subject     String   @default("")
  summary     String   @default("")
  /// Comma-separated project names Claude spotted.
  projects    String   @default("")
  /// Semicolon-separated follow-ups Claude spotted.
  actionItems String   @default("") @map("action_items")
  /// positive | neutral | negative (free-text; unknown renders slate).
  sentiment   String   @default("")
  /// The email's date as reported by the sheet (free-text; stored raw).
  emailDate   String   @default("") @map("email_date")
  syncedAt    DateTime @map("synced_at") @db.Timestamptz(6)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  company      Company?     @relation(fields: [companyId], references: [id], onDelete: SetNull)

  @@unique([orgId, externalKey])
  @@index([orgId])
  @@index([companyId])
  @@map("email_messages")
}

/// Unified timeline — everything that happens to a company lands here (spec §3.15).
model Activity {
  id          String   @id @default(uuid()) @db.Uuid
  orgId       String   @map("org_id") @db.Uuid
  companyId   String   @map("company_id") @db.Uuid
  /// Null for system-generated events.
  actorUserId String?  @map("actor_user_id") @db.Uuid
  /// note_added, intro_made, meeting_held, invoice_sent, status_changed, …
  type        String
  /// Type-specific detail.
  payload     Json     @default("{}")
  occurredAt  DateTime @map("occurred_at") @db.Timestamptz(6)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  company      Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  actor        User?        @relation("ActivityActor", fields: [actorUserId], references: [id])

  @@index([orgId])
  @@index([companyId, occurredAt(sort: Desc)])
  @@map("activities")
}

/// Per-org OAuth tokens, encrypted at rest (spec §3.16). Encryption happens at
/// the application layer before storage — the DB only ever sees ciphertext.
model IntegrationCredential {
  id              String    @id @default(uuid()) @db.Uuid
  orgId           String    @map("org_id") @db.Uuid
  /// fireflies, gmail, gcal, later quickbooks
  provider        String
  accessTokenEnc  Bytes     @map("access_token_enc")
  refreshTokenEnc Bytes?    @map("refresh_token_enc")
  scopes          String[]
  expiresAt       DateTime? @map("expires_at") @db.Timestamptz(6)
  /// Stamped at the end of a successful sync job (see @/lib/inngest). Null until
  /// the first sync runs — drives the dashboard sync-status card's freshness.
  lastSyncedAt    DateTime? @map("last_synced_at") @db.Timestamptz(6)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, provider])
  @@index([orgId])
  @@map("integration_credentials")
}

// ─────────────────────────────────────────────────────────────────────────────
// Slice 11.0 new tenant-scoped tables (full tenant treatment: org_id + RLS
// ENABLE/FORCE + tenant_isolation policy, added in the item-11.0 migration).
// ─────────────────────────────────────────────────────────────────────────────

/// Member dinners, roundtables, panels, site visits (demo `hvedc_events`).
model Event {
  id          String    @id @default(uuid()) @db.Uuid
  orgId       String    @map("org_id") @db.Uuid
  name        String
  /// member_dinner, roundtable, panel, site_visit, conference, social, other
  type        String
  /// planning, invitations_sent, confirmed, completed, cancelled
  stage       String    @default("planning")
  date        DateTime? @db.Timestamptz(6)
  venue       String?
  capacity    Int?
  theme       String?
  description String    @default("")
  notes       String    @default("")
  cost        Decimal?  @db.Decimal(14, 2)
  /// Optional tie to a project (e.g. a site visit). Plain FK to projects.id
  /// (a composite FK would force SetNull to null the required org_id) —
  /// app-layer re-checked inside withOrg on write, like introductions.projectId.
  projectId   String?   @map("project_id") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  organization Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  project      Project?       @relation(fields: [projectId], references: [id], onDelete: SetNull)
  invitees     EventInvitee[]

  // Composite-FK target for event_invitees (id, org_id).
  @@unique([id, orgId])
  @@index([orgId])
  @@index([orgId, date(sort: Desc)])
  @@index([projectId])
  @@map("events")
}

/// Guest list for an event — a CRM contact or an external (non-member) guest
/// (demo eventModal guest list). Composite FKs so an invitee can't straddle orgs.
model EventInvitee {
  // Synthetic PK: contactId is nullable (external guests), so it can't be part
  // of a composite PK — and one event may have several external guests.
  id           String  @id @default(uuid()) @db.Uuid
  orgId        String  @map("org_id") @db.Uuid
  eventId      String  @map("event_id") @db.Uuid
  /// Null when the guest is external (not in the CRM). Plain FK to contacts.id
  /// (a composite FK would force SetNull to null the required org_id) —
  /// app-layer re-checked inside withOrg on write, like contacts.companyId.
  contactId    String? @map("contact_id") @db.Uuid
  externalName String? @map("external_name")
  externalOrg  String? @map("external_org")
  /// invited, confirmed, declined, attended, no_show
  rsvp         String  @default("invited")
  notes        String  @default("")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  // Event is a required parent → composite FK keeps the invitee in the event's org.
  event        Event        @relation(fields: [eventId, orgId], references: [id, orgId], onDelete: Cascade)
  contact      Contact?     @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@index([orgId])
  @@index([eventId])
  @@index([contactId])
  @@map("event_invitees")
}

/// Membership proposals sent to companies (demo `hvedc_membership_proposals`).
/// Powers the dashboard "Proposals Sent" panel + revenue proposal pipeline.
model MembershipProposal {
  id             String    @id @default(uuid()) @db.Uuid
  orgId          String    @map("org_id") @db.Uuid
  companyId      String    @map("company_id") @db.Uuid
  /// Proposed tier (Director Level, Advisory Level, …).
  tier           String
  amount         Decimal?  @db.Decimal(14, 2)
  /// draft, sent, negotiating, won, lost
  status         String    @default("draft")
  sentOn         DateTime? @map("sent_on") @db.Date
  lastFollowUpAt DateTime? @map("last_follow_up_at") @db.Timestamptz(6)
  driveUrl       String?   @map("drive_url")
  notes          String    @default("")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  // Composite FK includes org_id so a proposal's company must be in the SAME org.
  company      Company      @relation(fields: [companyId, orgId], references: [id, orgId], onDelete: Cascade)

  @@index([orgId])
  @@index([companyId])
  @@index([orgId, status])
  @@map("membership_proposals")
}

/// Per-company Value Delivered ledger (slice P4). Records a concrete win the
/// network delivered to a member — an introduction that bore fruit, a grant, a
/// service rendered — with the outcome and the derived dollar value. Powers the
/// profile's Value Delivered card (per-member drill-down of value created); the
/// org-wide rollup stays on the Value Created page. Tenant-scoped: org_id + RLS.
model ValueDelivered {
  id             String   @id @default(uuid()) @db.Uuid
  orgId          String   @map("org_id") @db.Uuid
  companyId      String   @map("company_id") @db.Uuid
  /// introduction, service, grant, event, other (see @/lib/value-kinds)
  kind           String   @default("other")
  /// Optional link to the introduction that drove this value. Plain nullable FK
  /// (introductions has no composite (id, org_id) target) — app-layer re-checked
  /// inside withOrg on write, like introductions.projectId.
  introductionId String?  @map("introduction_id") @db.Uuid
  /// Derived dollar value; null when the value is non-monetary.
  amount         Decimal? @db.Decimal(14, 2)
  /// What was delivered.
  summary        String   @default("")
  /// The result / outcome.
  outcome        String   @default("")
  occurredAt     DateTime @map("occurred_at") @db.Date

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  organization Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  // Composite FK includes org_id so the recipient company must be in the SAME org.
  company      Company       @relation(fields: [companyId, orgId], references: [id, orgId], onDelete: Cascade)
  introduction Introduction? @relation(fields: [introductionId], references: [id], onDelete: SetNull)

  @@index([orgId])
  @@index([companyId])
  @@index([orgId, occurredAt(sort: Desc)])
  @@map("value_delivered")
}

/// Additional companies / affiliations for a member (slice P5). A member often
/// wears more than one hat — a separate business line or capacity (e.g. a bank
/// contact who also runs a private fund) — each with its own offer/need profile.
/// Captures those so the network sees (and can match on) every hat a member
/// wears. A lightweight sub-record of the owning company (flat text fields,
/// mirroring the prototype's inline editor); not a company row itself. Tenant-
/// scoped: org_id + RLS, composite company FK so it can only hang off an in-org
/// member.
model Affiliation {
  id         String @id @default(uuid()) @db.Uuid
  orgId      String @map("org_id") @db.Uuid
  companyId  String @map("company_id") @db.Uuid
  /// The affiliated company / business name.
  name       String @default("")
  /// The member's role there (e.g. Managing Partner).
  role       String @default("")
  industry   String @default("")
  website    String @default("")
  canOffer   String @default("") @map("can_offer")
  lookingFor String @default("") @map("looking_for")
  /// Free-text geography (e.g. "Dutchess, Ulster, Orange"), mirroring the
  /// prototype's flat sub-record.
  counties   String @default("")
  dealSize   String @default("") @map("deal_size")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  // Composite FK includes org_id so an affiliation can only hang off an in-org member.
  company      Company      @relation(fields: [companyId, orgId], references: [id, orgId], onDelete: Cascade)

  @@index([orgId])
  @@index([companyId])
  @@map("affiliations")
}

// ─────────────────────────────────────────────────────────────────────────────
// Slice 11.4c new tenant-scoped table (full tenant treatment: org_id + RLS
// ENABLE/FORCE + tenant_isolation policy, added in the 11.4c migration).
// ─────────────────────────────────────────────────────────────────────────────

/// Durable "don't suggest this pairing again" ledger for the introduction engine
/// (slice 11.4c; demo DISMISSED_KEY). When a user dismisses a suggested intro
/// between a FOCUS company and a CANDIDATE, we persist the directional pair plus a
/// reason so future per-member / proactive scans exclude it. Directional (focus →
/// candidate) mirrors how the per-member scan is run from one company's viewpoint;
/// the scan excludes both stored orientations to keep pairs from reappearing.
model IntroDismissal {
  id                 String @id @default(uuid()) @db.Uuid
  orgId              String @map("org_id") @db.Uuid
  focusCompanyId     String @map("focus_company_id") @db.Uuid
  candidateCompanyId String @map("candidate_company_id") @db.Uuid
  /// not_relevant, already_connected, competitor, wrong_timing (demo skip reasons)
  reason             String @default("not_relevant")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  // Composite FKs include org_id so both companies must be in the SAME org — a
  // dismissal can never reference a company in another tenant.
  focus        Company      @relation("IntroDismissalFocus", fields: [focusCompanyId, orgId], references: [id, orgId], onDelete: Cascade)
  candidate    Company      @relation("IntroDismissalCandidate", fields: [candidateCompanyId, orgId], references: [id, orgId], onDelete: Cascade)

  // One dismissal per directional pair — re-dismissing is an idempotent upsert.
  @@unique([orgId, focusCompanyId, candidateCompanyId])
  @@index([orgId])
  @@index([orgId, focusCompanyId])
  @@map("intro_dismissals")
}

/// New Connections Detected — durable triage queue for Fireflies meeting attendees
/// that matched NO contact (the prototype's UNMATCHED_KEY / "New Connections
/// Detected" panel). The sync records org-affiliated strangers here instead of
/// dropping them, so a human can promote one to a prospect or attach it to an
/// existing company. Tenant-scoped: org_id + RLS. No company/contact FK — these
/// rows are pre-CRM and reference nothing yet.
model UnmatchedAttendee {
  id               String    @id @default(uuid()) @db.Uuid
  orgId            String    @map("org_id") @db.Uuid
  /// Lowercased email — the natural de-dup key within an org.
  email            String
  /// Domain slice of the email; groups people by inferred organization.
  domain           String
  /// Best-guess person name (attendee display name, else email prefix).
  inferredName     String?   @map("inferred_name")
  /// Best-guess org name derived from the domain.
  inferredOrg      String?   @map("inferred_org")
  /// Distinct meeting ids this person appeared in — the idempotency source of
  /// truth: a re-sync only bumps seenCount when a NEW meeting id is added.
  meetingIds       String[]  @default([]) @map("meeting_ids") @db.Uuid
  /// = meetingIds.length, maintained on write so results can be ordered in SQL.
  seenCount        Int       @default(1) @map("seen_count")
  /// Title of the most recent meeting they appeared in (UI context).
  lastMeetingTitle String?   @map("last_meeting_title")
  /// Set when a human waves this person off — durable, survives re-sync.
  dismissedAt      DateTime? @map("dismissed_at") @db.Timestamptz(6)

  firstSeenAt DateTime @default(now()) @map("first_seen_at") @db.Timestamptz(6)
  lastSeenAt  DateTime @default(now()) @map("last_seen_at") @db.Timestamptz(6)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  // One row per (org, email); the sync upserts on this key.
  @@unique([orgId, email])
  @@index([orgId])
  @@index([orgId, domain])
  @@map("unmatched_attendees")
}

/// Per-org fixed-window counter that caps on-demand AI spend (audit L5+). One row
/// per tenant, keyed by org_id (no separate uuid PK — the org owns exactly one
/// budget). Two self-resetting windows: a short burst window (minute) and a daily
/// ceiling. Each permitted AI call bumps both counts; enforceAiRateLimit rolls a
/// window whose start has elapsed and refuses once either cap is hit. RLS-scoped
/// like every tenant table, so a tenant only ever reads/writes its own budget.
model AiRateLimit {
  orgId             String   @id @map("org_id") @db.Uuid
  /// Start of the current burst window; count resets when it elapses.
  minuteWindowStart DateTime @map("minute_window_start") @db.Timestamptz(6)
  minuteCount       Int      @default(0) @map("minute_count")
  /// Start of the current daily window; count resets when it elapses.
  dayWindowStart    DateTime @map("day_window_start") @db.Timestamptz(6)
  dayCount          Int      @default(0) @map("day_count")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@map("ai_rate_limits")
}
